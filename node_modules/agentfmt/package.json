{
  "name": "agentfmt",
  "version": "0.1.3",
  "description": "Token-efficient CLI output formatting for LLM agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cli",
    "output",
    "format",
    "llm",
    "agent",
    "terminal",
    "print"
  ],
  "author": "Danila Poyarkov <dev@dannote.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dannote/agentfmt.git"
  },
  "devDependencies": {
    "@types/bun": "^1.2.14",
    "oxfmt": "^0.26.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  }
}
